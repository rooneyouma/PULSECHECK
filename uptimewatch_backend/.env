# ==========================================
# PULSECHECK ENVIRONMENT CONFIGURATION
# ==========================================

# 1. SMTP Email Server Configuration (e.g., Gmail)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True

# 2. Email Account Settings
# Use an App Password if using Gmail (2FA), not your real password!
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password

# 3. Notification Settings
# The address that appears as the sender
DEFAULT_FROM_EMAIL=PulseCheck Alerts <alerts@pulsecheck.com>
# The address that RECEIVES the downtime alerts
ALERT_EMAIL=youremail@example.com

# 4. Redis Queue (For Celery)
REDIS_URL=redis://localhost:6379/0
